      <trkpt lat="38.0785" lon="-122.5930"><ele>90</ele></trkpt>
      <trkpt lat="38.0785" lon="-122.5950"><ele>80</ele></trkpt>
      <!-- Nicasio Valley - gentle rolling -->
      <trkpt lat="38.0800" lon="-122.5990"><ele>75</ele></trkpt>
      <trkpt lat="38.0820" lon="-122.6040"><ele>72</ele></trkpt>
      <trkpt lat="38.0850" lon="-122.6090"><ele>78</ele></trkpt>
      <trkpt lat="38.0880" lon="-122.6140"><ele>82</ele></trkpt>
      <trkpt lat="38.0910" lon="-122.6190"><ele>88</ele></trkpt>
      <trkpt lat="38.0940" lon="-122.6240"><ele>92</ele></trkpt>
      <!-- Climb to cheese factory -->
      <trkpt lat="38.0970" lon="-122.6300"><ele>100</ele></trkpt>
      <trkpt lat="38.1000" lon="-122.6360"><ele>115</ele></trkpt>
      <trkpt lat="38.1030" lon="-122.6420"><ele>130</ele></trkpt>
      <trkpt lat="38.1060" lon="-122.6480"><ele>148</ele></trkpt>
      <trkpt lat="38.1090" lon="-122.6540"><ele>160</ele></trkpt>
      <trkpt lat="38.1120" lon="-122.6600"><ele>172</ele></trkpt>
      <trkpt lat="38.1150" lon="-122.6660"><ele>180</ele></trkpt>
      <trkpt lat="38.1180" lon="-122.6720"><ele>185</ele></trkpt>
      <trkpt lat="38.1200" lon="-122.6800"><ele>190</ele></trkpt>
      <!-- Turnaround, descent back -->
      <trkpt lat="38.1180" lon="-122.6740"><ele>182</ele></trkpt>
      <trkpt lat="38.1150" lon="-122.6680"><ele>170</ele></trkpt>
      <trkpt lat="38.1120" lon="-122.6620"><ele>155</ele></trkpt>
      <trkpt lat="38.1090" lon="-122.6560"><ele>140</ele></trkpt>
      <trkpt lat="38.1060" lon="-122.6500"><ele>125</ele></trkpt>
      <trkpt lat="38.1030" lon="-122.6440"><ele>110</ele></trkpt>
      <trkpt lat="38.1000" lon="-122.6380"><ele>95</ele></trkpt>
      <!-- Rolling through Nicasio back -->
      <trkpt lat="38.0940" lon="-122.6260"><ele>85</ele></trkpt>
      <trkpt lat="38.0910" lon="-122.6210"><ele>80</ele></trkpt>
      <trkpt lat="38.0880" lon="-122.6160"><ele>75</ele></trkpt>
      <trkpt lat="38.0850" lon="-122.6110"><ele>72</ele></trkpt>
      <trkpt lat="38.0820" lon="-122.6060"><ele>70</ele></trkpt>
      <trkpt lat="38.0800" lon="-122.6010"><ele>72</ele></trkpt>
      <trkpt lat="38.0785" lon="-122.5960"><ele>78</ele></trkpt>
