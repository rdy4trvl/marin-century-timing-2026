      <trkpt lat="38.0690" lon="-122.5710"><ele>100</ele></trkpt>
      <trkpt lat="38.0670" lon="-122.5670"><ele>82</ele></trkpt>
      <trkpt lat="38.0650" lon="-122.5630"><ele>65</ele></trkpt>
      <trkpt lat="38.0630" lon="-122.5590"><ele>48</ele></trkpt>
      <trkpt lat="38.0610" lon="-122.5550"><ele>32</ele></trkpt>
