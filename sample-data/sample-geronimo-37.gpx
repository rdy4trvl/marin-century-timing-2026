<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="MarinCenturyTest"
  xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>Sample Route - Geronimo 37</name>
  </metadata>
  <wpt lat="38.0519" lon="-122.5312">
    <name>START - Marin Civic Center</name>
  </wpt>
  <wpt lat="38.0785" lon="-122.5950">
    <name>Nicasio Valley School RS</name>
  </wpt>
  <wpt lat="38.1200" lon="-122.6800">
    <name>Cheese Factory RS</name>
  </wpt>
  <wpt lat="38.0519" lon="-122.5312">
    <name>FINISH - Marin Civic Center</name>
  </wpt>
  <trk>
    <name>Geronimo 37</name>
    <trkseg>
      <!-- Start: Marin Civic Center, San Rafael (elev ~10m) -->
      <trkpt lat="38.0519" lon="-122.5312"><ele>3</ele></trkpt>
      <trkpt lat="38.0530" lon="-122.5340"><ele>5</ele></trkpt>
      <trkpt lat="38.0545" lon="-122.5370"><ele>8</ele></trkpt>
      <trkpt lat="38.0560" lon="-122.5410"><ele>12</ele></trkpt>
      <trkpt lat="38.0575" lon="-122.5450"><ele>18</ele></trkpt>
      <!-- Gentle climb through Lucas Valley -->
      <trkpt lat="38.0590" lon="-122.5490"><ele>25</ele></trkpt>
      <trkpt lat="38.0610" lon="-122.5530"><ele>35</ele></trkpt>
      <trkpt lat="38.0630" lon="-122.5570"><ele>48</ele></trkpt>
      <trkpt lat="38.0650" lon="-122.5610"><ele>62</ele></trkpt>
      <trkpt lat="38.0670" lon="-122.5650"><ele>78</ele></trkpt>
      <trkpt lat="38.0690" lon="-122.5690"><ele>95</ele></trkpt>
      <trkpt lat="38.0710" lon="-122.5730"><ele>110</ele></trkpt>
      <!-- Summit and descent to Nicasio -->
      <trkpt lat="38.0725" lon="-122.5770"><ele>120</ele></trkpt>
      <trkpt lat="38.0740" lon="-122.5810"><ele>125</ele></trkpt>
      <trkpt lat="38.0755" lon="-122.5850"><ele>118</ele></trkpt>
